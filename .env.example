# Copy this file to .env and enter your key. Never commit .env.
OPENAI_API_KEY=your_api_key_here

# Optional: choose a model for src/main.py
OPENAI_MODEL=gpt-5-mini

# Optional local persistence paths for M3 source evidence
# INSPO_MCP_DATABASE_PATH=data/inspo_mcp.db
# INSPO_MCP_CAPTURE_ROOT=data/captures

# Public contact address sent in the automated HTTP User-Agent.
INSPO_MCP_CONTACT_EMAIL=your-contact@example.com

# Minimum delay between automatic requests to the same host.
INSPO_MCP_MIN_HOST_REQUEST_INTERVAL_SECONDS=1.0
