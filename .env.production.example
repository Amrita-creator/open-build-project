# Copy this file to .env for Docker Compose. Do not commit the real token.
INSPO_MCP_ENVIRONMENT=production
INSPO_MCP_AUTH_TOKEN=replace-with-a-long-random-secret
INSPO_MCP_DATABASE_PATH=/var/lib/inspo-mcp/inspo_mcp.db
INSPO_MCP_CAPTURE_ROOT=/var/lib/inspo-mcp/captures
INSPO_MCP_HTTP_PATH=/mcp
INSPO_MCP_LOG_LEVEL=INFO
# Docker Compose sends safe HTTP and MCP-tool spans to the Jaeger dashboard.
INSPO_MCP_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://jaeger:4318/v1/traces
INSPO_MCP_CONTACT_EMAIL=operations@example.com
# Set only for direct browser-based MCP clients; never use * in production.
# INSPO_MCP_CORS_ORIGINS=https://app.example.com
